<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/nerf_tile_radius_small" />
            <gradient
                android:angle="270"
                android:startColor="@color/theme_shared_app_socket_outer_start"
                android:endColor="@color/theme_shared_app_socket_outer_end" />
            <stroke
                android:width="1dp"
                android:color="@color/theme_shared_app_socket_outer_stroke" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/nerf_tile_radius_small" />
            <gradient
                android:angle="270"
                android:startColor="@color/theme_shared_app_socket_middle_start"
                android:endColor="@color/theme_shared_app_socket_middle_end" />
            <stroke
                android:width="1dp"
                android:color="@color/theme_shared_app_socket_middle_stroke" />
        </shape>
    </item>

    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/nerf_tile_radius_small" />
            <solid android:color="@color/theme_shared_app_socket_inner_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/theme_shared_app_socket_inner_stroke" />
        </shape>
    </item>

    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp"
        android:gravity="top">
        <shape android:shape="rectangle">
            <size android:height="2dp" />
            <gradient
                android:angle="0"
                android:startColor="@color/theme_shared_app_socket_strip_start"
                android:endColor="@color/theme_shared_app_socket_strip_end" />
        </shape>
    </item>
</layer-list>
