<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/nerf_tile_radius_small" />
            <gradient
                android:angle="270"
                android:startColor="#B90A0D12"
                android:endColor="#D006070A" />
            <stroke
                android:width="1dp"
                android:color="#7F7E8797" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/nerf_tile_radius_small" />
            <gradient
                android:angle="270"
                android:startColor="#261D2632"
                android:endColor="#120A0E14" />
            <stroke
                android:width="1dp"
                android:color="#66444E61" />
        </shape>
    </item>

    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/nerf_tile_radius_small" />
            <solid android:color="#17000000" />
            <stroke
                android:width="1dp"
                android:color="#7734DFFF" />
        </shape>
    </item>

    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp"
        android:gravity="top">
        <shape android:shape="rectangle">
            <size android:height="2dp" />
            <gradient
                android:angle="0"
                android:startColor="#7A00E9FF"
                android:endColor="#0C00E9FF" />
        </shape>
    </item>
</layer-list>
