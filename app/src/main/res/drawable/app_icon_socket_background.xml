<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1000E9FF" />
            <stroke android:width="1dp" android:color="#5500E9FF" />
            <corners android:radius="@dimen/nerf_tile_radius_small" />
        </shape>
    </item>
    <item android:bottom="4dp" android:left="4dp" android:right="4dp" android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#1E000000" />
            <stroke android:width="1dp" android:color="#33FFFFFF" />
            <corners android:radius="@dimen/nerf_tile_radius_small" />
        </shape>
    </item>
</layer-list>
