<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="#2400E9FF"
                android:startColor="#30000000" />
            <stroke android:width="1dp" android:color="#FF00E9FF" />
            <corners android:radius="@dimen/nerf_tile_radius_small" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="#12000000"
                android:startColor="#1800E9FF" />
            <stroke android:width="1dp" android:color="@color/nerf_drawer_border" />
            <corners android:radius="@dimen/nerf_tile_radius_small" />
        </shape>
    </item>
</selector>
