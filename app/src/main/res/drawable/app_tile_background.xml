<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/nerf_tile_radius_small" />
                    <solid android:color="#ED05060A" />
                    <stroke
                        android:width="1dp"
                        android:color="#FF00E9FF" />
                </shape>
            </item>

            <item
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/nerf_tile_radius_small" />
                    <gradient
                        android:angle="270"
                        android:startColor="#EB2B323E"
                        android:endColor="#E310131A" />
                    <stroke
                        android:width="1dp"
                        android:color="#B780D9FF" />
                </shape>
            </item>

            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/nerf_tile_radius_small" />
                    <stroke
                        android:width="1dp"
                        android:color="#66131A24" />
                    <solid android:color="#12000000" />
                </shape>
            </item>

            <item
                android:left="4dp"
                android:top="3dp"
                android:right="4dp"
                android:bottom="4dp"
                android:gravity="top|start">
                <shape android:shape="rectangle">
                    <size android:height="2dp" />
                    <solid android:color="#A319EEFF" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/nerf_tile_radius_small" />
                    <solid android:color="#DE05060A" />
                    <stroke
                        android:width="1dp"
                        android:color="#AA6C7689" />
                </shape>
            </item>

            <item
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/nerf_tile_radius_small" />
                    <gradient
                        android:angle="270"
                        android:startColor="#D01A1E25"
                        android:endColor="#D10D1016" />
                    <stroke
                        android:width="1dp"
                        android:color="#7A8C97AB" />
                </shape>
            </item>

            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/nerf_tile_radius_small" />
                    <stroke
                        android:width="1dp"
                        android:color="#6610151D" />
                    <solid android:color="#10000000" />
                </shape>
            </item>

            <item
                android:left="4dp"
                android:top="3dp"
                android:right="4dp"
                android:bottom="4dp"
                android:gravity="top|start">
                <shape android:shape="rectangle">
                    <size android:height="2dp" />
                    <gradient
                        android:angle="0"
                        android:startColor="#7000E9FF"
                        android:endColor="#1400E9FF" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
