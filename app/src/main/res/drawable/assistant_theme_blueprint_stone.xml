<?xml version="1.0" encoding="utf-8"?>
<!-- Placeholder for Blueprint Stone assistant theme artwork.
     Replace this file with the real assistant_theme_blueprint_stone.png
     in drawable-nodpi/ for production use. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#FF080E16"
                android:centerColor="#FF0C1624"
                android:endColor="#FF060C14"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:top="120dp"
        android:bottom="320dp"
        android:left="80dp"
        android:right="80dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerColor="#3378A8D0"
                android:endColor="#0078A8D0"
                android:gradientRadius="120dp" />
        </shape>
    </item>
    <item
        android:top="60dp"
        android:bottom="500dp"
        android:left="100dp"
        android:right="100dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="#2278A8D0" />
        </shape>
    </item>
</layer-list>
