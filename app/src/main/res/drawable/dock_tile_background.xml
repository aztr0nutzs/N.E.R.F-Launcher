<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="3dp" />
                    <solid android:color="#E506080A" />
                    <stroke
                        android:width="1dp"
                        android:color="#FFFF39B5" />
                </shape>
            </item>
            <item
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="2dp" />
                    <gradient
                        android:angle="270"
                        android:startColor="#D72B1D3B"
                        android:endColor="#DB12141B" />
                    <stroke
                        android:width="1dp"
                        android:color="#C0FF74CC" />
                </shape>
            </item>
            <item
                android:left="3dp"
                android:top="3dp"
                android:right="3dp"
                android:bottom="3dp"
                android:gravity="bottom|end">
                <shape android:shape="rectangle">
                    <size android:height="2dp" />
                    <solid android:color="#88FF39B5" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="3dp" />
                    <solid android:color="#D507080A" />
                    <stroke
                        android:width="1dp"
                        android:color="#66A4FF00" />
                </shape>
            </item>
            <item
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="2dp" />
                    <solid android:color="#D7111318" />
                    <stroke
                        android:width="1dp"
                        android:color="#667B828C" />
                </shape>
            </item>
            <item
                android:left="3dp"
                android:top="3dp"
                android:right="3dp"
                android:bottom="3dp"
                android:gravity="top|start">
                <shape android:shape="rectangle">
                    <size android:height="2dp" />
                    <solid android:color="#66A4FF00" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
