<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#F008090D" />
            <stroke
                android:width="1dp"
                android:color="@color/nerf_drawer_border" />
        </shape>
    </item>

    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <gradient
                android:angle="270"
                android:startColor="#DB11141B"
                android:endColor="#E0090B10" />
            <stroke
                android:width="1dp"
                android:color="#5585A8C4" />
        </shape>
    </item>

    <item
        android:left="10dp"
        android:top="8dp"
        android:right="10dp"
        android:gravity="top">
        <shape android:shape="rectangle">
            <corners android:radius="1dp" />
            <size android:height="2dp" />
            <gradient
                android:angle="0"
                android:startColor="#0000E5FF"
                android:centerColor="#AA00E5FF"
                android:endColor="#0000E5FF" />
        </shape>
    </item>
</layer-list>
