<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="2dp" />
                    <solid android:color="#E307090C" />
                    <stroke
                        android:width="1dp"
                        android:color="#FF18E8FF" />
                </shape>
            </item>
            <item
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="1dp" />
                    <gradient
                        android:angle="270"
                        android:startColor="#D82B323A"
                        android:endColor="#DA12151B" />
                    <stroke
                        android:width="1dp"
                        android:color="#AA6DD9E5" />
                </shape>
            </item>
            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp"
                android:gravity="top|start">
                <shape android:shape="rectangle">
                    <size android:height="2dp" />
                    <solid android:color="#A018E8FF" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="2dp" />
                    <solid android:color="#D707080B" />
                    <stroke
                        android:width="1dp"
                        android:color="#66FF7B00" />
                </shape>
            </item>
            <item
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="1dp" />
                    <solid android:color="#D2101217" />
                    <stroke
                        android:width="1dp"
                        android:color="#666E7480" />
                </shape>
            </item>
            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp"
                android:gravity="bottom|end">
                <shape android:shape="rectangle">
                    <size android:height="1dp" />
                    <solid android:color="#80FF7B00" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
