<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="2dp" />
                    <solid android:color="@color/theme_shared_hud_action_pressed_outer_fill" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/theme_shared_hud_action_pressed_outer_stroke" />
                </shape>
            </item>
            <item
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="1dp" />
                    <gradient
                        android:angle="270"
                        android:startColor="@color/theme_shared_hud_action_pressed_inner_start"
                        android:endColor="@color/theme_shared_hud_action_pressed_inner_end" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/theme_shared_hud_action_pressed_inner_stroke" />
                </shape>
            </item>
            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp"
                android:gravity="top|start">
                <shape android:shape="rectangle">
                    <size android:height="2dp" />
                    <solid android:color="@color/theme_shared_hud_action_pressed_accent" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="2dp" />
                    <solid android:color="@color/theme_shared_hud_action_idle_outer_fill" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/theme_shared_hud_action_idle_outer_stroke" />
                </shape>
            </item>
            <item
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="1dp" />
                    <solid android:color="@color/theme_shared_hud_action_idle_inner_fill" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/theme_shared_hud_action_idle_inner_stroke" />
                </shape>
            </item>
            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp"
                android:gravity="bottom|end">
                <shape android:shape="rectangle">
                    <size android:height="1dp" />
                    <solid android:color="@color/theme_shared_hud_action_idle_accent" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
