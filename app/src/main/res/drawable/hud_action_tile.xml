<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#3318E8FF" />
            <stroke android:width="1dp" android:color="#FF18E8FF" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#220A0A0D" />
            <stroke android:width="1dp" android:color="#66FF7B00" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</selector>
