<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="2dp" />
            <solid android:color="#E1040405" />
            <stroke
                android:width="1dp"
                android:color="#8A00E9FF" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="2dp" />
            <solid android:color="#CC0B0C0F" />
            <stroke
                android:width="1dp"
                android:color="#66858B97" />
        </shape>
    </item>

    <item
        android:left="3dp"
        android:top="2dp"
        android:right="3dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="1dp" />
            <solid android:color="#D6111317" />
            <stroke
                android:width="1dp"
                android:color="#5525272D" />
        </shape>
    </item>

    <item
        android:left="3dp"
        android:top="2dp"
        android:right="28dp"
        android:bottom="2dp"
        android:gravity="start|center_vertical">
        <shape android:shape="rectangle">
            <corners android:radius="1dp" />
            <solid android:color="#A00EBED4" />
        </shape>
    </item>

    <item
        android:left="3dp"
        android:top="2dp"
        android:right="3dp"
        android:bottom="2dp"
        android:gravity="top|end">
        <shape android:shape="rectangle">
            <size android:height="2dp" />
            <solid android:color="#66FF7F11" />
        </shape>
    </item>
</layer-list>
