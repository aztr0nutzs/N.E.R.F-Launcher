<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#F0040507" />
            <stroke
                android:width="1dp"
                android:color="#8F00E9FF" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <solid android:color="#E80D1016" />
            <stroke
                android:width="1dp"
                android:color="#66AAAFBA" />
        </shape>
    </item>

    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="5dp" />
            <gradient
                android:angle="270"
                android:startColor="#ED161B22"
                android:centerColor="#D80D1015"
                android:endColor="#F007080B" />
            <stroke
                android:width="1dp"
                android:color="#58323745" />
        </shape>
    </item>

    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:gravity="top|start">
        <shape android:shape="rectangle">
            <size android:height="3dp" />
            <corners
                android:topLeftRadius="4dp"
                android:topRightRadius="4dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
            <gradient
                android:angle="0"
                android:startColor="#7A00E9FF"
                android:endColor="#1A00E9FF" />
        </shape>
    </item>

    <item
        android:left="4dp"
        android:right="4dp"
        android:bottom="4dp"
        android:gravity="bottom|end">
        <shape android:shape="rectangle">
            <size android:height="2dp" />
            <gradient
                android:angle="0"
                android:startColor="#14FF8A00"
                android:endColor="#80FF8A00" />
        </shape>
    </item>
</layer-list>
