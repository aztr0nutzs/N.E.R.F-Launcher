<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#EE050608" />
            <stroke
                android:width="1dp"
                android:color="#8A00E9FF" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="5dp" />
            <solid android:color="#DB101217" />
            <stroke
                android:width="1dp"
                android:color="#669098A7" />
        </shape>
    </item>

    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="3dp" />
            <gradient
                android:angle="270"
                android:startColor="#DC171A20"
                android:centerColor="#CF0F1116"
                android:endColor="#E708090C" />
            <stroke
                android:width="1dp"
                android:color="#55292C34" />
        </shape>
    </item>

    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp"
        android:gravity="top|start">
        <shape android:shape="rectangle">
            <size android:height="3dp" />
            <corners
                android:topLeftRadius="3dp"
                android:topRightRadius="3dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
            <gradient
                android:angle="0"
                android:startColor="#6600E9FF"
                android:endColor="#1A00E9FF" />
        </shape>
    </item>

    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp"
        android:gravity="bottom|end">
        <shape android:shape="rectangle">
            <size android:height="2dp" />
            <solid android:color="#4DFF8A00" />
        </shape>
    </item>
</layer-list>
