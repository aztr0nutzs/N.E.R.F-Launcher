<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#D9000000" />
            <stroke
                android:width="1dp"
                android:color="#6600E9FF" />
        </shape>
    </item>
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <gradient
                android:angle="270"
                android:startColor="#1AFF39B5"
                android:centerColor="#1A00E9FF"
                android:endColor="#1A9CFF00" />
            <stroke
                android:width="1dp"
                android:color="#33FFFFFF" />
        </shape>
    </item>
</layer-list>
