<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <size android:height="8dp" />
            <gradient
                android:angle="0"
                android:startColor="@color/theme_shared_quick_slider_cool_bg_start"
                android:endColor="@color/theme_shared_quick_slider_cool_bg_end" />
            <stroke android:width="1dp" android:color="@color/theme_shared_quick_slider_cool_bg_stroke" />
        </shape>
    </item>

    <item
        android:id="@android:id/secondaryProgress"
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="3dp" />
                <size android:height="6dp" />
                <solid android:color="@color/theme_shared_quick_slider_cool_secondary_fill" />
            </shape>
        </clip>
    </item>

    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="4dp" />
                <size android:height="8dp" />
                <gradient
                    android:angle="0"
                    android:startColor="@color/theme_shared_quick_slider_cool_progress_start"
                    android:centerColor="@color/theme_shared_quick_slider_cool_progress_center"
                    android:endColor="@color/theme_shared_quick_slider_cool_progress_end" />
            </shape>
        </clip>
    </item>
</layer-list>
