<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <size android:height="8dp" />
            <gradient
                android:angle="0"
                android:startColor="#2B090603"
                android:endColor="#4022170D" />
            <stroke android:width="1dp" android:color="#665A4631" />
        </shape>
    </item>

    <item
        android:id="@android:id/secondaryProgress"
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="3dp" />
                <size android:height="6dp" />
                <solid android:color="#335A452F" />
            </shape>
        </clip>
    </item>

    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="4dp" />
                <size android:height="8dp" />
                <gradient
                    android:angle="0"
                    android:startColor="#FF8A00"
                    android:centerColor="#FFE100"
                    android:endColor="#FF4D00" />
            </shape>
        </clip>
    </item>
</layer-list>
