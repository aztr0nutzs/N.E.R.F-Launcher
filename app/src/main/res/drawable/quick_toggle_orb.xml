<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <size android:width="44dp" android:height="44dp" />
                    <solid android:color="@color/theme_shared_quick_toggle_pressed_outer_fill" />
                    <stroke android:width="1dp" android:color="@color/theme_shared_quick_toggle_pressed_outer_stroke" />
                </shape>
            </item>
            <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
                <shape android:shape="oval">
                    <solid android:color="@color/theme_shared_quick_toggle_pressed_inner_fill" />
                    <stroke android:width="1dp" android:color="@color/theme_shared_quick_toggle_pressed_inner_stroke" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <size android:width="44dp" android:height="44dp" />
                    <gradient
                        android:angle="270"
                        android:startColor="@color/theme_shared_quick_toggle_idle_outer_start"
                        android:endColor="@color/theme_shared_quick_toggle_idle_outer_end" />
                    <stroke android:width="1dp" android:color="@color/theme_shared_quick_toggle_idle_outer_stroke" />
                </shape>
            </item>
            <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
                <shape android:shape="oval">
                    <solid android:color="@color/theme_shared_quick_toggle_idle_middle_fill" />
                    <stroke android:width="1dp" android:color="@color/theme_shared_quick_toggle_idle_middle_stroke" />
                </shape>
            </item>
            <item android:left="11dp" android:top="11dp" android:right="11dp" android:bottom="11dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:startColor="@color/theme_shared_quick_toggle_idle_inner_start"
                        android:endColor="@color/theme_shared_quick_toggle_idle_inner_end" />
                    <stroke android:width="1dp" android:color="@color/theme_shared_quick_toggle_idle_inner_stroke" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
