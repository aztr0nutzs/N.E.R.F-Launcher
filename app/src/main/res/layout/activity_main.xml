<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <View
        android:id="@+id/scanline_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/scanline_overlay"
        android:alpha="0.35"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:id="@+id/hud_shell"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp">

        <include
            android:id="@+id/hud_root"
            layout="@layout/hud_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/command_center"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="6dp"
            android:layout_weight="1"
            android:background="@drawable/hud_frame_panel"
            android:padding="4dp">

            <LinearLayout
                android:id="@+id/left_panel"
                style="@style/Widget.NerfLauncher.Hud.FramedPanel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginEnd="4dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/core_panel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.25">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APP GRID"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                    android:textColor="@color/nerf_hud_cyan" />

                <TextView
                    android:id="@+id/module_app_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="0 APPS"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueLarge" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="LOAD"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                    android:textColor="@color/nerf_hud_orange" />

                <com.nerf.launcher.ui.SegmentedBarView
                    android:id="@+id/apps_load_bar"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="CONFIG"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                    android:textColor="@color/nerf_hud_lime" />

                <TextView
                    android:id="@+id/module_grid_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="GRID 4x"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium" />

                <TextView
                    android:id="@+id/module_pinned_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="DOCK 4"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium" />

                <LinearLayout
                    android:id="@+id/quick_panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/quick_panel_background"
                    android:orientation="vertical"
                    android:paddingStart="8dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/quick_panel_title"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                        android:textColor="@color/nerf_hud_magenta" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/quick_panel_subtitle"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                        android:textColor="@color/nerf_hud_cyan" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/quick_control_rail"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="3dp"
                        android:text="@string/quick_row_palette"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                        android:textColor="@color/nerf_hud_cyan" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/quick_theme_btn"
                            style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/quick_toggle_orb"
                            android:contentDescription="@string/quick_theme_cd"
                            app:icon="@drawable/ic_quick_theme"
                            app:iconGravity="textStart"
                            app:iconPadding="4dp"
                            app:iconTint="@color/nerf_hud_cyan"
                            android:text="@string/quick_theme_label"
                            android:textColor="@color/nerf_hud_cyan"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/quick_icon_pack_btn"
                            style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/quick_toggle_orb"
                            android:contentDescription="@string/quick_icon_pack_cd"
                            app:icon="@drawable/ic_quick_icons"
                            app:iconGravity="textStart"
                            app:iconPadding="4dp"
                            app:iconTint="@color/nerf_hud_lime"
                            android:text="@string/quick_icon_pack_label"
                            android:textColor="@color/nerf_hud_lime"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/quick_control_rail"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="3dp"
                        android:text="@string/quick_row_runtime"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                        android:textColor="@color/nerf_hud_orange" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/quick_animation_btn"
                            style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/quick_toggle_orb"
                            android:contentDescription="@string/quick_animation_cd"
                            app:icon="@drawable/ic_quick_motion"
                            app:iconGravity="textStart"
                            app:iconPadding="4dp"
                            app:iconTint="@color/nerf_hud_orange"
                            android:text="@string/quick_animation_label"
                            android:textColor="@color/nerf_hud_orange"
                            android:textSize="10sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/quick_taskbar_btn"
                            style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/quick_toggle_orb"
                            android:contentDescription="@string/quick_taskbar_cd"
                            app:icon="@drawable/ic_quick_taskbar"
                            app:iconGravity="textStart"
                            app:iconPadding="4dp"
                            app:iconTint="@color/nerf_hud_magenta"
                            android:text="@string/quick_taskbar_label"
                            android:textColor="@color/nerf_hud_magenta"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/quick_control_rail"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="3dp"
                        android:text="@string/quick_row_calibration"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                        android:textColor="@color/nerf_hud_lime" />

                    <TextView
                        android:id="@+id/quick_glow_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                        android:textColor="@color/nerf_hud_cyan" />

                    <SeekBar
                        android:id="@+id/quick_glow_seekbar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:max="100"
                        android:progressDrawable="@drawable/quickslider_progress_cool"
                        android:thumbTint="@color/nerf_hud_cyan" />

                    <TextView
                        android:id="@+id/quick_grid_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                        android:textColor="@color/nerf_hud_orange" />

                    <SeekBar
                        android:id="@+id/quick_grid_seekbar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="4"
                        android:progressDrawable="@drawable/quickslider_progress_cool"
                        android:thumbTint="@color/nerf_hud_orange" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                    android:id="@+id/open_settings_tile"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/nerf_hud_button_height"
                    android:layout_marginTop="10dp"
                    android:text="SETTINGS"
                    android:textColor="@color/nerf_hud_cyan"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                    android:id="@+id/reload_tile"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/nerf_hud_button_height"
                    android:layout_marginTop="6dp"
                    android:text="SCAN APPS"
                    android:textColor="@color/nerf_hud_orange"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/lock_surface_tile"
                    style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/nerf_hud_button_height"
                    android:layout_marginTop="6dp"
                    android:contentDescription="@string/lock_surface_action_cd"
                    android:text="@string/lock_surface_action"
                    android:textColor="@color/nerf_hud_magenta"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/core_panel"
                style="@style/Widget.NerfLauncher.Hud.FramedPanel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginHorizontal="4dp"
                android:padding="6dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/right_panel"
                app:layout_constraintStart_toEndOf="@+id/left_panel"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.5">

                <ImageView
                    android:id="@+id/reactor_panel_art"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:alpha="0.22"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:scaleType="centerCrop"
                    android:src="@drawable/reactor_hud_mock"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/reactor_mode_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/reactor_home_title"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                    android:textColor="@color/nerf_hud_orange"
                    app:layout_constraintEnd_toStartOf="@+id/reactor_brand_mark"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/reactor_brand_mark"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:alpha="0.36"
                    android:contentDescription="@string/nerf_brand_mark_cd"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_brand_mark_main"
                    app:layout_constraintBottom_toBottomOf="@id/reactor_mode_label"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/reactor_mode_label" />

                <TextView
                    android:id="@+id/reactor_status_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/reactor_home_status_ready"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium"
                    android:textColor="@color/nerf_hud_cyan"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/reactor_mode_label" />

                <com.nerf.launcher.ui.reactor.ReactorModuleView
                    android:id="@+id/reactor_core"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:contentDescription="@string/reactor_core_cd"
                    app:layout_constraintBottom_toTopOf="@+id/reactor_legend_panel"
                    app:layout_constraintDimensionRatio="1:1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/reactor_status_text"
                    app:layout_constraintVertical_bias="0.42"
                    app:layout_constraintWidth_percent="0.88" />

                <FrameLayout
                    android:id="@+id/reactor_legend_panel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/panel_background"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/reactor_sync_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/reactor_home_sync_default"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueLarge"
                            android:textColor="@color/nerf_hud_panel_text_primary" />

                        <TextView
                            android:id="@+id/reactor_hint_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/reactor_home_hint"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_panel_text_secondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/reactor_home_active_rails"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_orange" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/reactor_home_action_top"
                                android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                                android:textColor="@color/nerf_hud_cyan" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="end"
                                android:text="@string/reactor_home_action_right"
                                android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                                android:textColor="@color/nerf_hud_orange" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/reactor_home_action_left"
                                android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                                android:textColor="@color/nerf_hud_lime" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="end"
                                android:text="@string/reactor_home_action_bottom"
                                android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                                android:textColor="@color/nerf_hud_magenta" />
                        </LinearLayout>
                    </LinearLayout>
                </FrameLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/right_panel"
                style="@style/Widget.NerfLauncher.Hud.FramedPanel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="4dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/core_panel"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.25">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/modules_system_title"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                    android:textColor="@color/nerf_hud_lime" />

                <FrameLayout
                    android:id="@+id/module_energy_card"
                    style="@style/Widget.NerfLauncher.Hud.StatCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/panel_background"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/modules_energy_label"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_orange" />

                        <TextView
                            android:id="@+id/module_energy_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="--%"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueLarge"
                            android:textColor="@color/nerf_hud_orange" />

                        <com.nerf.launcher.ui.SegmentedBarView
                            android:id="@+id/module_energy_bar"
                            android:layout_width="match_parent"
                            android:layout_height="14dp"
                            android:layout_marginTop="5dp" />
                    </LinearLayout>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/module_storage_card"
                        style="@style/Widget.NerfLauncher.Hud.StatCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/module_stat_card2"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/modules_storage_label"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_cyan" />

                        <TextView
                            android:id="@+id/module_storage_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="N/A"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium"
                            android:textColor="@color/nerf_hud_panel_text_primary" />

                        <com.nerf.launcher.ui.SegmentedBarView
                            android:id="@+id/module_storage_bar"
                            android:layout_width="match_parent"
                            android:layout_height="9dp"
                            android:layout_marginTop="5dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/module_runtime_card"
                        style="@style/Widget.NerfLauncher.Hud.StatCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/modules_runtime_label"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_magenta" />

                        <TextView
                            android:id="@+id/module_runtime_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="0h 0m"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium"
                            android:textColor="@color/nerf_hud_panel_text_primary" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/module_state_card"
                        style="@style/Widget.NerfLauncher.Hud.StatCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/modules_state_label"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_lime" />

                        <TextView
                            android:id="@+id/module_state_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="ACTIVE"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium"
                            android:textColor="@color/nerf_hud_lime" />
                    </LinearLayout>

                    <FrameLayout
                        style="@style/Widget.NerfLauncher.Hud.StatCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.nerf.launcher.ui.ReactorCoreView
                                android:layout_width="58dp"
                                android:layout_height="58dp"
                                android:alpha="0.95"
                                android:clickable="false"
                                android:focusable="false"
                                android:importantForAccessibility="no" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/modules_reactor_label"
                                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                                    android:textColor="@color/nerf_hud_orange" />

                                <TextView
                                    android:id="@+id/module_reactor_value"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:gravity="end"
                                    android:text="SYNC 0%"
                                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueLarge"
                                    android:textColor="@color/nerf_hud_panel_text_primary" />
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/drawer_shell"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/drawer_shell_background"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/drawer_shell_title"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_magenta" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/drawer_shell_subtitle"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_panel_text_secondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/drawer_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/drawer_shell_background"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/drawer_header_label"
                                android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                                android:textColor="@color/nerf_hud_magenta" />

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:alpha="0.86"
                                android:contentDescription="@string/drawer_brand_mark_cd"
                                android:src="@drawable/ic_brand_mark_main" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/drawer_result_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="0 VISIBLE"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium"
                            android:textColor="@color/nerf_hud_cyan" />

                        <EditText
                            android:id="@+id/drawerSearchInput"
                            style="@style/Widget.NerfLauncher.Drawer.SearchInput"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/nerf_drawer_search_height"
                            android:layout_marginTop="8dp"
                            android:hint="@string/drawer_search_hint"
                            android:imeOptions="actionDone"
                            android:inputType="text"
                            android:maxLines="1"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:textColor="@color/nerf_hud_panel_text_primary"
                            android:textColorHint="@color/nerf_hud_panel_text_secondary" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/drawer_shell_background"
                        android:clipToPadding="false"
                        android:paddingStart="4dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="6dp"
                        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                        app:spanCount="2" />
                </LinearLayout>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.nerf.launcher.ui.TaskbarView
            android:id="@+id/taskbarView"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal" />
    </LinearLayout>

    <include
        android:id="@+id/assistant_overlay"
        layout="@layout/layout_assistant_overlay" />

    <LinearLayout
        android:id="@+id/lock_surface_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F0000000"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:background="@drawable/hud_frame_panel"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/lock_surface_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/lock_surface_title"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                android:textColor="@color/nerf_hud_magenta" />

            <TextView
                android:id="@+id/lock_surface_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueLarge"
                android:textColor="@color/nerf_hud_cyan"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lock_surface_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium"
                android:textColor="@color/nerf_hud_panel_text_primary" />

            <TextView
                android:id="@+id/lock_surface_scope_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/lock_surface_scope_note"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                android:textColor="@color/nerf_hud_panel_text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/lock_surface_unlock_button"
                style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/nerf_hud_button_height"
                android:layout_marginTop="12dp"
                android:contentDescription="@string/lock_surface_unlock"
                android:text="@string/lock_surface_unlock"
                android:textColor="@color/nerf_hud_lime"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
