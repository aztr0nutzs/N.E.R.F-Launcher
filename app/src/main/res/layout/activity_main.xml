<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <View
        android:id="@+id/scanline_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/scanline_overlay"
        android:alpha="0.35"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:id="@+id/hud_shell"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp">

        <include
            android:id="@+id/hud_root"
            layout="@layout/hud_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/command_center"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="6dp"
            android:layout_weight="1"
            android:background="@drawable/hud_frame_panel"
            android:padding="4dp">

            <LinearLayout
                android:id="@+id/left_panel"
                style="@style/Widget.NerfLauncher.Hud.FramedPanel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginEnd="4dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/core_panel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.25">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APP GRID"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                    android:textColor="@color/nerf_hud_cyan" />

                <TextView
                    android:id="@+id/module_app_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="0 APPS"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueLarge" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="LOAD"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                    android:textColor="@color/nerf_hud_orange" />

                <com.nerf.launcher.ui.SegmentedBarView
                    android:id="@+id/apps_load_bar"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="CONFIG"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                    android:textColor="@color/nerf_hud_lime" />

                <TextView
                    android:id="@+id/module_grid_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="GRID 4x"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium" />

                <TextView
                    android:id="@+id/module_pinned_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="DOCK 4"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium" />

                <LinearLayout
                    android:id="@+id/quick_panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/quick_panel_background"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/quick_panel_title"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                        android:textColor="@color/nerf_hud_magenta" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/quick_theme_btn"
                            style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/quick_toggle_orb"
                            android:contentDescription="@string/quick_theme_cd"
                            android:text="@string/quick_theme_label"
                            android:textColor="@color/nerf_hud_cyan"
                            android:textSize="11sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/quick_icon_pack_btn"
                            style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/quick_toggle_orb"
                            android:contentDescription="@string/quick_icon_pack_cd"
                            android:text="@string/quick_icon_pack_label"
                            android:textColor="@color/nerf_hud_lime"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/quick_animation_btn"
                            style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/quick_toggle_orb"
                            android:contentDescription="@string/quick_animation_cd"
                            android:text="@string/quick_animation_label"
                            android:textColor="@color/nerf_hud_orange"
                            android:textSize="11sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/quick_taskbar_btn"
                            style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/quick_toggle_orb"
                            android:contentDescription="@string/quick_taskbar_cd"
                            android:text="@string/quick_taskbar_label"
                            android:textColor="@color/nerf_hud_magenta"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/quick_glow_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                        android:textColor="@color/nerf_hud_cyan" />

                    <SeekBar
                        android:id="@+id/quick_glow_seekbar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:max="100"
                        android:progressDrawable="@drawable/quick_slider_progress"
                        android:thumbTint="@color/nerf_hud_cyan" />

                    <TextView
                        android:id="@+id/quick_grid_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                        android:textColor="@color/nerf_hud_orange" />

                    <SeekBar
                        android:id="@+id/quick_grid_seekbar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="4"
                        android:progressDrawable="@drawable/quick_slider_progress_warm"
                        android:thumbTint="@color/nerf_hud_orange" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                    android:id="@+id/open_settings_tile"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/nerf_hud_button_height"
                    android:layout_marginTop="10dp"
                    android:text="SETTINGS"
                    android:textColor="@color/nerf_hud_cyan"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                    android:id="@+id/reload_tile"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/nerf_hud_button_height"
                    android:layout_marginTop="6dp"
                    android:text="SCAN APPS"
                    android:textColor="@color/nerf_hud_orange"
                    android:textSize="12sp" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/core_panel"
                style="@style/Widget.NerfLauncher.Hud.FramedPanel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginHorizontal="4dp"
                android:padding="6dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/right_panel"
                app:layout_constraintStart_toEndOf="@+id/left_panel"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.5">

                <com.nerf.launcher.ui.ReactorCoreView
                    android:id="@+id/reactor_core"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/reactor_core_cd" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/right_panel"
                style="@style/Widget.NerfLauncher.Hud.FramedPanel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="4dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/core_panel"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.25">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/modules_system_title"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                    android:textColor="@color/nerf_hud_lime" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/module_energy_card"
                        style="@style/Widget.NerfLauncher.Hud.StatCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/modules_energy_label"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_orange" />

                        <TextView
                            android:id="@+id/module_energy_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="--%"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium" />

                        <com.nerf.launcher.ui.SegmentedBarView
                            android:id="@+id/module_energy_bar"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/module_storage_card"
                        style="@style/Widget.NerfLauncher.Hud.StatCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/modules_storage_label"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_cyan" />

                        <TextView
                            android:id="@+id/module_storage_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="N/A"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium" />

                        <com.nerf.launcher.ui.SegmentedBarView
                            android:id="@+id/module_storage_bar"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/module_runtime_card"
                        style="@style/Widget.NerfLauncher.Hud.StatCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/modules_runtime_label"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_magenta" />

                        <TextView
                            android:id="@+id/module_runtime_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="0h 0m"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/module_state_card"
                        style="@style/Widget.NerfLauncher.Hud.StatCard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/modules_state_label"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_lime" />

                        <TextView
                            android:id="@+id/module_state_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="ACTIVE"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    style="@style/Widget.NerfLauncher.Hud.StatCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/modules_reactor_label"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                        android:textColor="@color/nerf_hud_orange" />

                    <TextView
                        android:id="@+id/module_reactor_value"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="SYNC 0%"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium"
                        android:textColor="@color/nerf_hud_panel_text_primary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/drawer_shell"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/drawer_shell_background"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/drawer_shell_title"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_magenta" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/drawer_shell_subtitle"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_panel_text_secondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/drawer_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/drawer_header_panel"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/drawer_header_label"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                            android:textColor="@color/nerf_hud_magenta" />

                        <TextView
                            android:id="@+id/drawer_result_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="0 VISIBLE"
                            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium"
                            android:textColor="@color/nerf_hud_cyan" />

                        <EditText
                            android:id="@+id/drawerSearchInput"
                            style="@style/Widget.NerfLauncher.Drawer.SearchInput"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/nerf_drawer_search_height"
                            android:layout_marginTop="8dp"
                            android:hint="@string/drawer_search_hint"
                            android:imeOptions="actionDone"
                            android:inputType="text"
                            android:maxLines="1"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:textColor="@color/nerf_hud_panel_text_primary"
                            android:textColorHint="@color/nerf_hud_panel_text_secondary" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/drawer_header_panel"
                        android:clipToPadding="false"
                        android:paddingStart="4dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="6dp"
                        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                        app:spanCount="2" />
                </LinearLayout>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.nerf.launcher.ui.TaskbarView
            android:id="@+id/taskbarView"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal" />
    </LinearLayout>

</FrameLayout>
