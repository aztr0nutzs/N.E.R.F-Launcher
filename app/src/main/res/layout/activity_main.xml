<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <View
        android:id="@+id/scanline_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/scanline_overlay"
        android:alpha="0.35"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:id="@+id/hud_shell"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="8dp">

        <include
            android:id="@+id/hud_root"
            layout="@layout/hud_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/command_center"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/left_panel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/hud_frame_panel"
                android:orientation="vertical"
                android:padding="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/core_panel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.28">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APP GRID"
                    android:textColor="#00E9FF"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/module_app_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="0 APPS"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="LOAD"
                    android:textColor="#FF8A00"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <com.nerf.launcher.ui.SegmentedBarView
                    android:id="@+id/apps_load_bar"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="CONFIG"
                    android:textColor="#9CFF00"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/module_grid_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="GRID 4x"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/module_pinned_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="DOCK 4"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/open_settings_tile"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/hud_action_tile"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="SETTINGS"
                    android:textAllCaps="false"
                    android:textColor="#00E9FF"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/reload_tile"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/hud_action_tile"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="SCAN APPS"
                    android:textAllCaps="false"
                    android:textColor="#FF8A00"
                    android:textSize="12sp" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/core_panel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="2dp"
                android:background="@drawable/hud_frame_panel"
                android:padding="10dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/right_panel"
                app:layout_constraintStart_toEndOf="@+id/left_panel"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.44">

                <com.nerf.launcher.ui.ReactorCoreView
                    android:id="@+id/reactor_core"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/reactor_core_cd" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/right_panel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/hud_frame_panel"
                android:orientation="vertical"
                android:padding="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/core_panel"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.28">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LAUNCH MATRIX"
                    android:textColor="#FF39B5"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.nerf.launcher.ui.TaskbarView
            android:id="@+id/taskbarView"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal" />
    </LinearLayout>

</FrameLayout>
