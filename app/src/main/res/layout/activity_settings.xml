<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nerf_shell_background">

    <View
        android:id="@+id/scanline_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.30"
        android:background="@drawable/scanline_overlay"
        android:importantForAccessibility="no" />

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/hud_frame_panel"
        android:theme="@style/Theme.NerfLauncher">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:popupTheme="@style/Theme.NerfLauncher.PopupOverlay"/>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:paddingStart="@dimen/nerf_space_12"
        android:paddingTop="@dimen/nerf_space_12"
        android:paddingEnd="@dimen/nerf_space_12"
        android:paddingBottom="@dimen/nerf_space_12"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/settings_header_card"
            style="@style/Widget.NerfLauncher.Hud.FramedPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/nerf_space_12">

            <TextView
                android:id="@+id/settings_header_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_surface_title"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                android:textColor="@color/theme_shared_hud_cyan" />

            <TextView
                android:id="@+id/settings_header_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/nerf_space_4"
                android:text="@string/settings_surface_subtitle"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                android:textColor="@color/theme_shared_hud_orange" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/open_taskbar_settings_button"
                style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/nerf_settings_cta_height"
                android:layout_marginTop="@dimen/nerf_space_10"
                android:text="@string/settings_taskbar_cta"
                android:textColor="@color/theme_shared_hud_magenta" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/settings_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/nerf_space_10"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/nerf_space_10" />
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
