<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/taskbar_settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nerf_shell_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/Theme.NerfLauncher">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/nerf_primary"
            app:popupTheme="@style/Theme.NerfLauncher.PopupOverlay" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/taskbar_settings_enabled"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Body1" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/taskbarEnabledSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/taskbar_settings_height"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Body1" />

            <TextView
                android:id="@+id/taskbarHeightValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Caption" />

            <SeekBar
                android:id="@+id/taskbarHeightSeekbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/taskbar_settings_icon_size"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Body1" />

            <TextView
                android:id="@+id/taskbarIconSizeValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Caption" />

            <SeekBar
                android:id="@+id/taskbarIconSizeSeekbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/taskbar_settings_transparency"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Body1" />

            <TextView
                android:id="@+id/taskbarTransparencyValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Caption" />

            <SeekBar
                android:id="@+id/taskbarTransparencySeekbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/taskbar_settings_background_style"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Body1" />

            <Spinner
                android:id="@+id/taskbarBackgroundStyleSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/taskbar_settings_pinned_apps"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Body1" />

            <TextView
                android:id="@+id/pinnedAppsSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Caption" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/clearPinnedAppsButton"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/taskbar_settings_clear_pins" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
