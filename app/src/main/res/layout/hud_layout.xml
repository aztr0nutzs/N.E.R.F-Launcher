<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/hud_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="top"
    android:padding="8dp">

    <LinearLayout
        android:id="@+id/hud_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Battery ammo meter -->
        <LinearLayout
            android:id="@+id/battery_container"
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/battery_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BAT"
                android:textColor="@color/nerf_on_primary"
                android:textSize="12sp"
                android:layout_marginEnd="4dp"/>

            <ProgressBar
                android:id="@+id/battery_meter"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="16dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="50"
                android:progressTint="@color/nerf_primary"
                android:backgroundTint="@color/nerf_surface"
                android:indeterminate="false"/>
        </LinearLayout>

        <!-- Time display -->
        <TextView
            android:id="@+id/time_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:00"
            android:textSize="20sp"
            android:textColor="@color/nerf_on_background"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <!-- Widget area -->
        <FrameLayout
            android:id="@+id/widget_container"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/panel_background"
            android:elevation="2dp">

            <Button
                android:id="@+id/add_widget_btn"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="+ WIDGET"
                android:background="?attr/materialButtonStyle"
                android:textColor="@color/nerf_on_primary"
                android:textAllCaps="false"/>
        </FrameLayout>
    </LinearLayout>
</FrameLayout>