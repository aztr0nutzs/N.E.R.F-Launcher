<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/hud_root"
    style="@style/Widget.NerfLauncher.Hud.FramedPanel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/time_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.Time" />

        <TextView
            android:id="@+id/date_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/nerf_space_2"
            android:text=""
            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.Date" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/battery_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/battery_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/nerf_space_6"
            android:text="@string/modules_energy_label"
            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
            android:textColor="@color/theme_shared_hud_orange" />

        <com.nerf.launcher.ui.SegmentedBarView
            android:id="@+id/battery_meter"
            android:layout_width="0dp"
            android:layout_height="@dimen/nerf_hud_meter_height"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/battery_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/nerf_space_6"
            android:text=""
            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.BatteryPercent" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/nerf_section_gap"
        android:layout_marginEnd="@dimen/nerf_section_gap"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="@dimen/nerf_hud_brand_mark_size"
            android:layout_height="@dimen/nerf_hud_brand_mark_size"
            android:alpha="0.82"
            android:contentDescription="@string/nerf_brand_mark_cd"
            android:src="@drawable/ic_brand_mark_main" />

        <TextView
            android:id="@+id/brand_signature"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/nerf_space_6"
            android:text="@string/hud_brand_signature"
            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
            android:textColor="@color/theme_shared_hud_panel_text_secondary" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
        android:id="@+id/add_widget_btn"
        android:layout_width="@dimen/nerf_hud_action_button_width"
        android:layout_height="@dimen/nerf_hud_button_small_height"
        android:layout_marginStart="@dimen/nerf_section_gap"
        android:text="@string/hud_settings_action"
        android:textColor="@color/theme_shared_hud_lime"
        android:textSize="@dimen/nerf_text_size_hud_button"
        app:icon="@drawable/ic_settings"
        app:iconGravity="textStart"
        app:iconPadding="@dimen/nerf_space_6"
        app:iconSize="@dimen/nerf_hud_icon_size" />
</LinearLayout>
