<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/hud_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/hud_frame_panel"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/time_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:00"
            android:textColor="#00E9FF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/date_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="MON 01 JAN"
            android:textColor="#66FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/battery_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="ENERGY"
            android:textColor="#FF8A00"
            android:textSize="11sp"
            android:textStyle="bold" />

        <com.nerf.launcher.ui.SegmentedBarView
            android:id="@+id/battery_meter"
            android:layout_width="0dp"
            android:layout_height="12dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/battery_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="50%"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/add_widget_btn"
        android:layout_width="96dp"
        android:layout_height="36dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/hud_action_tile"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="SETTINGS"
        android:textAllCaps="false"
        android:textColor="#9CFF00"
        android:textSize="12sp" />
</LinearLayout>
