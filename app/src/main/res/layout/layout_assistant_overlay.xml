<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/assistant_overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/assistant_overlay_card"
        android:layout_width="308dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="68dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/hud_frame_panel"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawablePadding="6dp"
                    android:drawableStart="@drawable/ic_assistant"
                    android:text="@string/assistant_overlay_title"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                    android:textColor="@color/nerf_hud_magenta" />

                <TextView
                    android:id="@+id/assistant_overlay_bank_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                    android:textColor="@color/nerf_hud_panel_text_secondary" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/assistant_overlay_close_button"
                style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:text="@string/assistant_overlay_close"
                android:textColor="@color/nerf_hud_orange"
                android:textSize="12sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="122dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/drawer_shell_background">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.3"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:scaleType="centerCrop"
                android:src="@drawable/reactor_assistant_cutout" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp">

                <com.nerf.launcher.ui.ReactorCoreView
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:alpha="0.96"
                    android:clickable="false"
                    android:focusable="false"
                    android:importantForAccessibility="no" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/assistant_overlay_visual_label"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                        android:textColor="@color/nerf_hud_cyan" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/assistant_overlay_visual_hint"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium"
                        android:textColor="@color/nerf_hud_panel_text_primary" />

                    <TextView
                        android:id="@+id/assistant_overlay_mood_indicator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/assistant_overlay_mood_indicator_idle"
                        android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
                        android:textColor="@color/nerf_hud_magenta" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/assistant_overlay_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/assistant_overlay_status_idle"
            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
            android:textColor="@color/nerf_hud_cyan" />

        <TextView
            android:id="@+id/assistant_overlay_response"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/drawer_shell_background"
            android:padding="10dp"
            android:text="@string/assistant_overlay_response_idle"
            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium"
            android:textColor="@color/nerf_hud_panel_text_primary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/assistant_overlay_transcript_label"
            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
            android:textColor="@color/nerf_hud_orange" />

        <ScrollView
            android:id="@+id/assistant_overlay_transcript_container"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/drawer_shell_background"
            android:fillViewport="true"
            android:padding="10dp">

            <TextView
                android:id="@+id/assistant_overlay_transcript"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/assistant_overlay_transcript_empty"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium"
                android:textColor="@color/nerf_hud_panel_text_primary" />
        </ScrollView>

        <LinearLayout
            android:id="@+id/assistant_overlay_input_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/assistant_overlay_command_input"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/drawer_shell_background"
                android:hint="@string/assistant_overlay_command_hint"
                android:imeOptions="actionSend"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.ValueMedium"
                android:textColor="@color/nerf_hud_panel_text_primary"
                android:textColorHint="@color/nerf_hud_panel_text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/assistant_overlay_submit_button"
                style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                android:layout_width="74dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:text="@string/assistant_overlay_submit"
                android:textColor="@color/nerf_hud_cyan"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/assistant_overlay_voice_controls_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/assistant_overlay_mic_button"
                style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:contentDescription="@string/assistant_overlay_mic_cd"
                android:text="@string/assistant_overlay_mic"
                android:textColor="@color/nerf_hud_lime"
                android:textSize="10sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/assistant_overlay_repeat_last_button"
                style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="@string/assistant_overlay_repeat_last"
                android:textColor="@color/nerf_hud_magenta"
                android:textSize="10sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/assistant_overlay_interrupt_button"
                style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="@string/assistant_overlay_interrupt"
                android:textColor="@color/nerf_hud_orange"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/assistant_overlay_actions_label"
            android:textAppearance="@style/TextAppearance.NerfLauncher.Hud.SectionLabel"
            android:textColor="@color/nerf_hud_lime" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/assistant_action_settings"
                style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="@string/assistant_overlay_action_settings"
                android:textColor="@color/nerf_hud_cyan"
                android:textSize="10sp"
                app:icon="@drawable/ic_settings"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/assistant_action_diagnostics"
                style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="@string/assistant_overlay_action_diagnostics"
                android:textColor="@color/nerf_hud_orange"
                android:textSize="10sp"
                app:icon="@drawable/ic_camera"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="16dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/assistant_action_node_hunter"
                style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:text="@string/assistant_overlay_action_node_hunter"
                android:textColor="@color/nerf_hud_lime"
                android:textSize="10sp"
                app:icon="@drawable/ic_node_hunter"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/assistant_action_lock"
                style="@style/Widget.NerfLauncher.Hud.ActionTileButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:text="@string/assistant_overlay_action_lock"
                android:textColor="@color/nerf_hud_magenta"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
