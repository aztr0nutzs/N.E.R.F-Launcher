<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.NerfLauncher" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="nerfPrimaryVariantColor">@color/nerf_primary_dark</item>
        <item name="nerfSurfaceColor">@color/nerf_surface</item>
        <item name="nerfWindowBackgroundColor">@color/theme_shared_window_background</item>
        <item name="nerfHudPanelTextPrimaryColor">@color/theme_shared_hud_panel_text_primary</item>
        <item name="nerfHudPanelTextSecondaryColor">@color/theme_shared_hud_panel_text_secondary</item>
        <item name="nerfHudInfoColor">@color/theme_shared_hud_cyan</item>
        <item name="nerfHudWarningColor">@color/theme_shared_hud_orange</item>
        <item name="nerfHudSuccessColor">@color/theme_shared_hud_lime</item>
        <item name="nerfHudAccentColor">@color/theme_shared_hud_magenta</item>
        <item name="nerfHudAppLabelColor">@color/theme_shared_hud_app_label</item>

        <!-- Primary brand colors. -->
        <item name="colorPrimary">@color/theme_classic_primary</item>
        <item name="colorPrimaryVariant">?attr/nerfPrimaryVariantColor</item>
        <item name="colorOnPrimary">?attr/nerfHudPanelTextPrimaryColor</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/theme_classic_secondary</item>
        <item name="colorSecondaryVariant">@color/theme_classic_secondary</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorTertiary">@color/theme_classic_accent</item>

        <!-- Background & surface. -->
        <item name="android:colorBackground">?attr/nerfWindowBackgroundColor</item>
        <item name="colorSurface">?attr/nerfSurfaceColor</item>
        <item name="colorOnBackground">?attr/nerfHudPanelTextPrimaryColor</item>
        <item name="colorOnSurface">?attr/nerfHudPanelTextPrimaryColor</item>

        <!-- Status bar. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <item name="android:navigationBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>

        <!-- Material button style. -->
        <item name="materialButtonStyle">@style/Widget.NerfLauncher.Button</item>

        <!-- Text appearances. -->
        <item name="textAppearanceHeadline5">@style/TextAppearance.NerfLauncher.Headline5</item>
        <item name="textAppearanceBody1">@style/TextAppearance.NerfLauncher.Body1</item>
        <item name="textAppearanceCaption">@style/TextAppearance.NerfLauncher.Caption</item>

        <!-- Window background. -->
        <item name="android:windowBackground">?attr/nerfWindowBackgroundColor</item>
    </style>

    <style name="Theme.NerfLauncher.PopupOverlay" parent="ThemeOverlay.MaterialComponents" />

    <!-- Custom Button style with press bounce & glow. -->
    <style name="Widget.NerfLauncher.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_background</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:stateListAnimator">@anim/button_press</item>
        <item name="android:elevation">2dp</item>
    </style>

    <!-- Home-shell reusable container and tile styles. -->
    <style name="WidgetNerfLauncherBase" />

    <style name="Widget.NerfLauncher.Hud" parent="WidgetNerfLauncherBase" />

    <style name="Widget.NerfLauncher.Hud.FramedPanel" parent="Widget.NerfLauncher.Hud">
        <item name="android:background">@drawable/hud_frame_panel</item>
        <item name="android:padding">@dimen/nerf_panel_padding</item>
    </style>

    <style name="Widget.NerfLauncher.Hud.ActionTileButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/hud_action_tile</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>

    <style name="Widget.NerfLauncher.Hud.StatCard" parent="Widget.NerfLauncher.Hud">
        <item name="android:background">@drawable/module_stat_card</item>
        <item name="android:padding">10dp</item>
    </style>

    <!-- Text appearances. -->

    <style name="Widget.NerfLauncher.Drawer" parent="WidgetNerfLauncherBase" />

    <style name="Widget.NerfLauncher.Drawer.SearchInput" parent="Widget.NerfLauncher.Drawer">
        <item name="android:background">@drawable/drawer_search_field_background</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">?attr/colorOnBackground</item>
    </style>
    <style name="TextAppearance.NerfLauncher.Headline5" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">?attr/colorOnBackground</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">?attr/colorOnBackground</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">?attr/colorOnBackground</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.SectionLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.SectionLabel.Cyan" parent="TextAppearance.NerfLauncher.Hud.SectionLabel">
        <item name="android:textColor">?attr/nerfHudInfoColor</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.SectionLabel.Orange" parent="TextAppearance.NerfLauncher.Hud.SectionLabel">
        <item name="android:textColor">?attr/nerfHudWarningColor</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.SectionLabel.Lime" parent="TextAppearance.NerfLauncher.Hud.SectionLabel">
        <item name="android:textColor">?attr/nerfHudSuccessColor</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.SectionLabel.Magenta" parent="TextAppearance.NerfLauncher.Hud.SectionLabel">
        <item name="android:textColor">?attr/nerfHudAccentColor</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.SectionLabel.Primary" parent="TextAppearance.NerfLauncher.Hud.SectionLabel">
        <item name="android:textColor">?attr/nerfHudPanelTextPrimaryColor</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.SectionLabel.Secondary" parent="TextAppearance.NerfLauncher.Hud.SectionLabel">
        <item name="android:textColor">?attr/nerfHudPanelTextSecondaryColor</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.ValueLarge" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">?attr/nerfHudPanelTextPrimaryColor</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.ValueLarge.Cyan" parent="TextAppearance.NerfLauncher.Hud.ValueLarge">
        <item name="android:textColor">?attr/nerfHudInfoColor</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.ValueLarge.Orange" parent="TextAppearance.NerfLauncher.Hud.ValueLarge">
        <item name="android:textColor">?attr/nerfHudWarningColor</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.ValueMedium" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">?attr/nerfHudPanelTextPrimaryColor</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.ValueMedium.Cyan" parent="TextAppearance.NerfLauncher.Hud.ValueMedium">
        <item name="android:textColor">?attr/nerfHudInfoColor</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.ValueMedium.Lime" parent="TextAppearance.NerfLauncher.Hud.ValueMedium">
        <item name="android:textColor">?attr/nerfHudSuccessColor</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.Time" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">?attr/nerfHudInfoColor</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.Date" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">?attr/nerfHudPanelTextSecondaryColor</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.BatteryPercent" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">?attr/nerfHudPanelTextPrimaryColor</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="TextAppearance.NerfLauncher.Hud.AppTileLabel" parent="TextAppearance.NerfLauncher.Caption">
        <item name="android:textColor">?attr/nerfHudAppLabelColor</item>
        <item name="android:textSize">10sp</item>
    </style>
</resources>
